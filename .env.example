# Copy this file to `.env` and fill in your credentials, then either:
#   - export them:   set -a && source .env && set +a
#   - or use a tool like `direnv` / `dotenv`.
#
# synthfc reads ALL secrets from the environment. Nothing secret lives in the
# YAML config or in the code.

# --- Provider selection -----------------------------------------------------
# "openai" for any OpenAI-compatible API, "azure" for Azure OpenAI.
SYNTHFC_PROVIDER=openai

# Model / deployment name to call (the teacher model).
SYNTHFC_MODEL=gpt-4o

# --- Credentials ------------------------------------------------------------
# API key (SYNTHFC_API_KEY takes precedence; OPENAI_API_KEY also works).
SYNTHFC_API_KEY=sk-your-key-here

# Endpoint / base URL.
#   - OpenAI:            leave unset (defaults to https://api.openai.com/v1)
#   - OpenAI-compatible: e.g. http://localhost:8000/v1  (vLLM, Together, Groq, ...)
#   - Azure OpenAI:      https://YOUR-RESOURCE.openai.azure.com/   (REQUIRED)
# SYNTHFC_ENDPOINT=

# Azure-only API version (ignored for the openai provider).
# SYNTHFC_API_VERSION=2024-10-21

# --- Optional ---------------------------------------------------------------
# Override where generated batches are written (default: ./data).
# SYNTHFC_DATA_DIR=

# Use a config file other than configs/default.yaml.
# SYNTHFC_CONFIG=
